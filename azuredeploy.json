{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "parameters": {
    "webAppName": {
      "type": "string",
      "defaultValue": "emeka-website",
      "minLength": 2,
      "maxLength": 60,
      "metadata": {
        "description": "The name of the Azure Web App. Must be globally unique — becomes <name>.azurewebsites.net"
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "F1",
      "allowedValues": ["F1", "B1", "B2", "S1", "S2", "P1v3"],
      "metadata": {
        "description": "Pricing tier. F1 = Free (dev/test). B1+ required for custom domains & SSL."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Defaults to the resource group's region."
      }
    },
    "linuxFxVersion": {
      "type": "string",
      "defaultValue": "NODE|20-lts",
      "metadata": {
        "description": "Runtime stack. NODE|20-lts is ideal for serving static HTML via a lightweight Node server."
      }
    }
  },

  "variables": {
    "appServicePlanName": "[concat(parameters('webAppName'), '-plan')]",
    "appInsightsName":    "[concat(parameters('webAppName'), '-insights')]",
    "uniqueWebAppName":   "[concat(parameters('webAppName'), '-', uniqueString(resourceGroup().id))]"
  },

  "resources": [

    /* ─────────────────────────────────────────────
       1. App Service Plan (Linux)
    ───────────────────────────────────────────── */
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('sku')]",
        "tier": "[if(equals(parameters('sku'),'F1'),'Free', if(startsWith(parameters('sku'),'B'),'Basic', if(startsWith(parameters('sku'),'S'),'Standard','PremiumV3')))]"
      },
      "properties": {
        "reserved": true,
        "zoneRedundant": false
      },
      "tags": {
        "project":     "emeka-website",
        "environment": "production",
        "managedBy":   "ARM"
      }
    },

    /* ─────────────────────────────────────────────
       2. Application Insights (optional monitoring)
          Skipped on F1 — no alerts on free tier
    ───────────────────────────────────────────── */
    {
      "condition": "[not(equals(parameters('sku'),'F1'))]",
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "Request_Source":   "rest",
        "RetentionInDays":  30,
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery":     "Enabled"
      },
      "tags": {
        "project":     "emeka-website",
        "environment": "production"
      }
    },

    /* ─────────────────────────────────────────────
       3. Azure Web App
    ───────────────────────────────────────────── */
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[variables('uniqueWebAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "clientAffinityEnabled": false,
        "siteConfig": {
          "linuxFxVersion": "[parameters('linuxFxVersion')]",
          "alwaysOn": "[not(equals(parameters('sku'),'F1'))]",
          "http20Enabled": true,
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",

          /* Startup command: serve index.html via a tiny Node.js static server */
          "appCommandLine": "npx serve -s . -l 8080",

          "appSettings": [
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~20"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "false"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[if(not(equals(parameters('sku'),'F1')), reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')),'2020-02-02').InstrumentationKey, '')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[if(not(equals(parameters('sku'),'F1')), reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')),'2020-02-02').ConnectionString, '')]"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            }
          ],

          /* Custom response headers for security */
          "httpSettings": {
            "requireHttps": true
          }
        }
      },
      "tags": {
        "project":     "emeka-website",
        "environment": "production",
        "owner":       "Emeka"
      }
    },

    /* ─────────────────────────────────────────────
       4. Web App Config — security headers & MIME
    ───────────────────────────────────────────── */
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2022-09-01",
      "name": "[concat(variables('uniqueWebAppName'), '/web')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('uniqueWebAppName'))]"
      ],
      "properties": {
        "defaultDocuments": ["index.html"],
        "use32BitWorkerProcess": false,
        "webSocketsEnabled": false,
        "requestTracingEnabled": true,
        "httpLoggingEnabled": true,
        "logsDirectorySizeLimit": 35,
        "detailedErrorLoggingEnabled": false,
        "ipSecurityRestrictions": [],
        "scmIpSecurityRestrictions": [],
        "scmIpSecurityRestrictionsUseMain": false,
        "cors": {
          "allowedOrigins": ["*"],
          "supportCredentials": false
        }
      }
    }

  ],

  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('uniqueWebAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', variables('uniqueWebAppName'), '.azurewebsites.net')]"
    },
    "appServicePlanName": {
      "type": "string",
      "value": "[variables('appServicePlanName')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "deploymentInstructions": {
      "type": "string",
      "value": "After deployment, upload index.html via 'az webapp deploy' or VS Code Azure extension. See README.md for full steps."
    }
  }
}
